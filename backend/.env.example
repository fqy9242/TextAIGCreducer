APP_NAME=Text AIGC Reducer
DEBUG=false
API_V1_PREFIX=/api/v1

SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

DATABASE_URL=sqlite+aiosqlite:///./aigc_reducer.db
SYNC_DATABASE_URL=sqlite:///./aigc_reducer.db

CORS_ORIGINS=http://localhost:5173

PROMPTS_ROOT=../prompts/zh-CN

# Runtime defaults and non-secret LLM parameters are managed in the web admin UI.
# Only keep the secret key in env.
OPENAI_API_KEY=

DETECTOR_PROVIDER=mock
DETECTOR_HTTP_URL=http://127.0.0.1:9000/detect
DETECTOR_HTTP_TIMEOUT_SECONDS=20
TASK_EXECUTION_TIMEOUT_SECONDS=1800
TASK_WORKER_CONCURRENCY=2

EXTERNAL_SKILL_ENABLED=true
EXTERNAL_SKILL_REPO_ROOT=skills
EXTERNAL_SKILL_MODE=de-AI-writing
EXTERNAL_SKILL_MAX_ITEMS=12

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=Admin@123456
